generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// RLS is explicitly DISABLED (default-deny) on all tables Prisma touches.
/// Enforcement happens at the API layer via code-level role checks in serverless
/// functions. Do NOT add Supabase RLS policies to these tables — Prisma's
/// service-role connection bypasses RLS, so policies would silently do nothing
/// or, worse, conflict with the API-layer checks.

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  position  String
  role      String   // "super_admin" | "staff" | "client"
  mustChangePassword Boolean @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  createdEvents Event[]       @relation("EventCreator")
  attendance    Attendance[]
  recorded      Attendance[]  @relation("RecordedBy")
  officeDuties  OfficeDuty[]

  @@map("users")
}

model Event {
  id           String   @id @default(uuid())
  title        String
  date         DateTime
  lat          Float
  lng          Float
  radiusMeters Int      @default(50)
  createdBy    String
  creator      User     @relation("EventCreator", fields: [createdBy], references: [id])
  attendance   Attendance[]
  createdAt    DateTime @default(now())

  @@map("events")
}

model Attendance {
  id         String    @id @default(uuid())
  type       String    @default("event") // "event" | "duty"
  eventId    String?
  dutyDate   DateTime? // required if type = "duty"
  userId     String
  method     String    // "self" | "manual" | "qr"
  lat        Float?
  lng        Float?
  recordedBy String
  createdAt  DateTime  @default(now())
  checkOutAt DateTime?

  event    Event?  @relation(fields: [eventId], references: [id])
  user     User    @relation(fields: [userId], references: [id])
  recorder User    @relation("RecordedBy", fields: [recordedBy], references: [id])

  @@map("attendance")
}

model OfficeDuty {
  id        String  @id @default(uuid())
  userId    String
  dayOfWeek Int     // 0 = Sunday .. 6 = Saturday
  startTime String  // "08:00"
  endTime   String  // "17:00"
  active    Boolean @default(true)
  user      User    @relation(fields: [userId], references: [id])

  @@map("office_duties")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  // user being acted upon (nullable for system actions)
  action      String   // "account_created", "password_changed", "password_reset", "officer_deactivated", "role_changed", "manual_override"
  details     String?  // JSON string with additional context
  performedBy String?  // user ID of the admin/system performing the action
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model OrgProfile {
  id                  String @id @default(uuid())
  dutyCheckInCutoff   String @default("12:00") // HH:mm 24hr — duty check-ins must occur before this
  dutyCheckOutStart   String @default("12:00") // HH:mm 24hr — duty check-outs must occur at or after this

  @@map("org_profile")
}
